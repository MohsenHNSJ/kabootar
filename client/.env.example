# App
APP_HOST=0.0.0.0
APP_PORT=8090
APP_SECRET_KEY=change-me

# SQLite DB
DATABASE_URL=sqlite:///./data/app.db

# Telegram channels (comma-separated usernames)
CHANNELS_ADDRESS=durov,telegram

# Telegram proxies (comma-separated). Supports:
# socks5://ip:port
# socks5://user:pass@ip:port
# socks5://ip:port:user:pass
# http://ip:port
# http://user:pass@ip:port
TELEGRAM_PROXIES=

# Sync interval for cron installer (minutes)
CRON_INTERVAL_MINUTES=15

# Optional Rocket.Chat forwarding
ROCKET_URL=
ROCKET_ADMIN_USER=
ROCKET_ADMIN_PASS=
ROCKET_ROOM_NAME=
# per channel mapping tg:rcroom,tg2:rcroom2
CHANNELS_MAPPING=
